# Sao chép file này thành .env rồi điền giá trị thật vào
# KHÔNG commit file .env lên GitHub

# ── KeyCloak Admin ────────────────────────────────────────
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=your_admin_password_here

# ── Database ──────────────────────────────────────────────
DB_USER=keycloak
DB_PASSWORD=your_db_password_here

# ── Keycloak Server ────────────────
KEYCLOAK_PORT=8080

# ── Client App ────────────────────────────────────────────
KC_REALM=myrealm
KC_CLIENT_ID=myapp
KC_CLIENT_SECRET=your_client_secret_here
KC_SERVER_URL=http://localhost:8080

APP_PORT=3000
SESSION_SECRET=your_random_session_secret_here

# ── Social Login (điền sau khi tạo OAuth App) ─────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
