# HƯỚNG DẪN: Sao chép file này thành .env và điền giá trị thật.
# ⚠️ QUAN TRỌNG: KHÔNG ĐƯỢC commit file .env lên GitHub để tránh lộ mật khẩu.

# ── KeyCloak Admin (Tài khoản quản trị của Keycloak) ──
# Dùng để đăng nhập vào trang http://localhost:8080/admin
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=your_admin_password_here       # Nên đổi thành mật khẩu mạnh hơn khi triển khai thực tế

# ── Database (Thông số kết nối cơ sở dữ liệu) ────────────────
# Keycloak sẽ dùng thông tin này để tạo và quản lý bảng trong DB
DB_USER=keycloak
DB_PASSWORD=your_db_password_here       # Mật khẩu dùng cho PostgreSQL trong Docker

# ── Keycloak Server ──────────────────────────────────────────
KEYCLOAK_PORT=8080            # Cổng chạy dịch vụ Keycloak (mặc định 8080)

# ── Client App (Thông tin kết nối giữa App và Keycloak) ──────
KC_REALM=uit-keycloak-realm   # Tên Realm bạn đã tạo trong Keycloak
KC_CLIENT_ID=myapp     # ID của Client đã tạo trong mục Clients
KC_CLIENT_SECRET=your_secret  # Lấy tại tab 'Credentials' của Client trong Keycloak
KC_SERVER_URL=http://localhost:8080 # Đường dẫn gốc của Server Keycloak

# Thông số của ứng dụng Node.js/React của nhóm
APP_PORT=3000                 # Cổng chạy ứng dụng phía Client
SESSION_SECRET=random_string  # Một chuỗi ký tự ngẫu nhiên bất kỳ để mã hóa phiên làm việc

# ── Social Login (Thông tin từ các nền tảng bên thứ ba) ──────
# Điền các giá trị này sau khi tạo OAuth App trên Google/GitHub Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
