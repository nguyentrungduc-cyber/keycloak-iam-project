<%- include('layout') %>
<div class="min-h-screen bg-gray-950 text-white p-8">
  <h1 class="text-3xl font-bold mb-6">Dashboard</h1>
  <div class="bg-gray-900 p-6 rounded-2xl">
    <p><strong>Xin chào:</strong> <%= user.preferred_username || user.name %></p>
    <p><strong>Email:</strong> <%= user.email %></p>
    <p><strong>Roles:</strong> <%= roles.join(', ') %></p>
    <a href="/auth/logout" class="mt-6 inline-block bg-red-600 hover:bg-red-700 px-6 py-3 rounded-xl">Đăng xuất</a>
  </div>
</div>
