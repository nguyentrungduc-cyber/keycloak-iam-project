{
  "realm": "myapp-realm",
  "enabled": true,
  "sslRequired": "external",
  "clients": [
    {
      "clientId": "myapp-frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": ["http://localhost:3000/*", "http://localhost:8080/*"],
      "webOrigins": ["+"]
    }
  ],
  "identityProviders": [
    {"alias": "google", "providerId": "google"},
    {"alias": "github", "providerId": "github"}
  ]
}
