<div class="dashboard-wrap">

  <div class="dash-topbar-card">
    <div class="dash-brand">
      <div class="logo-wrap small">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
          <circle cx="12" cy="12" r="8" stroke="white" stroke-width="2" />
          <circle cx="12" cy="12" r="2.5" fill="white" />
        </svg>
      </div>
      <span class="app-name">MyApp</span>
    </div>
    <div class="dash-user">
      <div class="avatar-circle">
        <%= (user.given_name || user.name || 'U' ).charAt(0).toUpperCase() %>
      </div>
      <span class="user-name">
        <%= user.name || user.preferred_username %>
      </span>
      <a href="/auth/logout" class="btn-logout">Đăng xuất</a>
    </div>
  </div>

  <div class="stat-row">
    <div class="stat-card">
      <div class="stat-label">Phương thức đăng nhập</div>
      <div class="stat-value">
        <%= user.sub ? 'OIDC / Keycloak' : 'Unknown' %>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Email</div>
      <div class="stat-value">
        <%= user.email || '—' %>
      </div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Phiên hoạt động</div>
      <div class="stat-value" id="session-timer">—</div>
    </div>
  </div>

  <div class="dash-panels">

    <div class="panel">
      <div class="panel-title">JWT Payload (giải mã)</div>
      <pre class="code-block"><%= JSON.stringify(user, null, 2) %></pre>

      <div class="panel-title" style="margin-top:16px;">Roles hiện tại</div>
      <div class="roles-row">
        <% if (roles && roles.length> 0) { %>
          <% roles.forEach(role=> { %>
            <span class="role-badge role-<%= role.toLowerCase() %>">
              <%= role %>
            </span>
            <% }) %>
              <% } else { %>
                <span style="color:#666;font-size:13px;">Không có role nào</span>
                <% } %>
      </div>
    </div>

<div class="panel">
      <div class="panel-title">Quyền truy cập (RBAC)</div>
      <div class="rbac-list">
        <%
          /* Phân quyền thực tế dựa trên mảng roles của Keycloak */
          const hasAdmin  = roles.includes('admin');
          const hasEditor = roles.includes('editor');
          
          const perms = [
            { label: 'Xem danh sách user',  ok: hasAdmin || hasEditor },
            { label: 'Tạo user mới',         ok: hasAdmin },
            { label: 'Xóa user',             ok: hasAdmin },
            { label: 'Xem báo cáo',          ok: hasAdmin || hasEditor },
            { label: 'Cài đặt hệ thống',     ok: hasAdmin },
            { label: 'Export database',      ok: false },
          ];
          
          perms.forEach(p => {
        %>
          <div class="rbac-row">
            <span class="rbac-label"><%= p.label %></span>
            <span class="rbac-badge <%= p.ok ? 'allow' : 'deny' %>">
              <%= p.ok ? 'Cho phép' : 'Từ chối' %>
            </span>
          </div>
        <% }) %>
      </div>
    </div>

  </div>
</div>

<script>
  // Đếm thời gian session
  const start = Date.now();
  function tick() {
    const s = Math.floor((Date.now() - start) / 1000);
    const m = Math.floor(s / 60), sec = s % 60;
    document.getElementById('session-timer').textContent =
      m + ':' + (sec < 10 ? '0' : '') + sec;
  }
  tick();
  setInterval(tick, 1000);
</script>